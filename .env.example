# Copy this file to .env and fill only the values you want to override.
# Do not commit .env.
#
# LensRhyme can boot without model, OSS, TTS/ASR, or Seedance credentials.
# Configure those later in Admin -> Platform Configuration.

# Compose project and registry image selection.
# IMAGE_TAG should be a release tag created from the application repository.
# Overseas is the default and pulls public images from Docker Hub. Deployment
# scripts resolve China mode to Aliyun ACR; direct Compose users should select
# compose/docker-compose.aliyun.yml or set IMAGE_REGISTRY explicitly. The same
# release tag must already be mirrored to ACR.
COMPOSE_PROJECT_NAME=lens-rhyme
DEPLOYMENT_REGION=overseas
IMAGE_REGISTRY=shikanon096
IMAGE_TAG=latest

# Published SEO/GEO content frontend. Keep the revalidation secret shared by
# backend and content-frontend; production requires at least 32 characters.
CONTENT_SITE_URL=https://lensrhyme.com
CONTENT_PRODUCT_URL=https://lensrhyme.com/login
CONTENT_SOURCE=api
CONTENT_API_BASE_URL=http://backend:8000/api/v1/public/content
CONTENT_API_REQUIRED=1
CONTENT_API_REVALIDATE_SECONDS=300
CONTENT_FRONTEND_REVALIDATION_URLS=http://content-frontend:3002/internal/content/revalidate
CONTENT_REVALIDATION_SECRET=
CONTENT_CDN_PURGE_ENDPOINT=
CONTENT_CDN_PURGE_TOKEN=
CONTENT_MEDIA_HOSTS=lensrhyme.tos-cn-hongkong.volces.com,cdn.lens-rhyme.tensorbytes.com
INDEXNOW_ENABLED=false
INDEXNOW_KEY=
INDEXNOW_KEY_LOCATION=https://lensrhyme.com/indexnow-key.txt

# Production should use a unique random value.
# If left empty, Docker Compose uses its local bootstrap default.
SECRET_KEY=

# Initial Super Admin bootstrap.
# If left empty, the app uses admin / admin123 and forces a password change.
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=

# Internal service tokens. Use unique random values in production.
# OPENVIKING_CLIENT_API_KEY must be a non-root user/admin data API key and must
# not match OPENVIKING_ROOT_API_KEY.
OPENVIKING_CLIENT_API_KEY=
OPENVIKING_ROOT_API_KEY=
CODEX_RUNNER_MANAGER_TOKEN=

# Optional Codex bootstrap.
# Leave empty if you will upload auth.json from Admin -> Platform Configuration.
OPENAI_API_KEY=

# Optional OpenViking upstream key for multimodal retrieval.
# Backend model credentials should be configured in the Admin UI instead.
OPENVIKING_API_KEY=

# Optional public backend base URL used only for local/mock download URLs.
# Production ResourceFS downloads should normally use OSS/CDN below.
PUBLIC_BASE_URL=http://localhost:8000

# Optional object storage / ResourceFS storage configuration.
# The backend also reads Admin -> Platform Configuration; these env vars let
# Compose deployments work before or without manually syncing platform config.
OBJECT_STORAGE_PROVIDER=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_ACCESS_KEY_SECRET=
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_BUCKET_NAME=
OBJECT_STORAGE_CDN_DOMAIN=
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_ADDRESSING_STYLE=virtual
OBJECT_STORAGE_CONNECT_TIMEOUT=
OBJECT_STORAGE_READ_TIMEOUT=
OBJECT_STORAGE_MOCK_UPLOAD=false

RESOURCEFS_BUCKET=resources
RESOURCEFS_CDN_BASE_URL=
RESOURCEFS_CDN_SIGNING_SECRET=

# Optional deployment initializer.
# Keep test data disabled for production.
DEPLOYMENT_INIT_TEST_DATA=false
TEST_USER_USERNAME=test_user
TEST_USER_PASSWORD=

# Optional Admin Platform Configuration defaults as a JSON object.
# Existing admin-set values are not overwritten unless force is true.
DEPLOYMENT_INIT_PLATFORM_CONFIG_JSON=
DEPLOYMENT_INIT_PLATFORM_CONFIG_FORCE=false
